---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
}

const { title = "Hemeroteca TGP" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/images/tgp-img-16.webp" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Preconnect to Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<!-- Import Gloock, Newsreader and Space Mono -->
		<link href="https://fonts.googleapis.com/css2?family=Gloock&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-theme-dark text-[#F5F5F7] antialiased selection:bg-white/20 selection:text-white flex flex-col min-h-screen">
		<Header />
		<main class="grow relative">
			<slot />
		</main>
		<Footer />
	</body>
</html>
