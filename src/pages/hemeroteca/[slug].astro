---
import { render, getEntry, getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { marked } from 'marked';
import { StickyReaderHeader } from "../../components/StickyReaderHeader";
import { QuickReturnButton } from "../../components/QuickReturnButton";
import SubstackPrefooter from "../../components/SubstackPrefooter.astro";
import RelatedReading from "../../components/RelatedReading.astro";
import ExploreMore from "../../components/ExploreMore.astro";

export const prerender = true;
export async function getStaticPaths() {
  const essays = await getCollection("ensayos");
  // Nota: No filtramos por draft para asegurar que se generen todos los ensayos solicitados (27+)

  return essays.map((item) => ({
    params: { slug: item.id.replace(/\/index$/, "") },
    props: { data: item.data },
  }));
}

const { slug } = Astro.params;
const { data } = Astro.props;

// Obtenemos el contenido usando la nueva colección de contenido para evitar el uso de fs.readFile
const contentEntry = await getEntry("ensayosContent", `${slug}/content`);

if (!contentEntry) {
  throw new Error(`No se pudo encontrar el contenido para ${slug}`);
}

const { Content } = await render(contentEntry);
const contentData = contentEntry.data; 

// 1. ORO ESTRICTO: Importación dinámica exclusiva de la portada local
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/ensayos/**/*.{jpeg,jpg,png,gif,webp,avif}",
);
const ensayoPath = data.coverImage;
let optimizedImage = null;

if (ensayoPath && images[ensayoPath]) {
  try {
    const { default: loadedImage } = await images[ensayoPath]();
    optimizedImage = loadedImage;
  } catch (err) {
    console.warn(
      `[ERROR] No image module could be loaded for ${ensayoPath}:`,
      err,
    );
  }
}
// Tolerancia para borradores que no tengan imagen todavía, manteniendo el background antracita por seguridad.

const roomColors: Record<string, string> = {
  "british-green": "#1B382A",
  bordeaux: "#5B2326",
  "old-navy": "#1E2C3A",
  "bus-red": "#8B3A36",
  "vintage-yellow": "#D4A352",
  "rust-orange": "#B55A30",
};
const activeAccent = data.themeColor
  ? roomColors[data.themeColor] || "#ffffff"
  : "#ffffff";
---

<Layout title={`${data.title} | Hemeroteca TGP`}>
  <StickyReaderHeader client:load title={data.title || "Ensayo TGP"} accentColor={activeAccent} />
  <QuickReturnButton client:load accentColor={activeAccent} />

  {/* 2. Hero Cinemático Full-Width con Parallax Nativo Constante */}
  <section
    class="hero-section relative w-full h-screen flex flex-col justify-end pb-24 px-6 md:px-12 lg:px-24 z-10 overflow-hidden"
  >
    {
      /* Fondo Fijo: La imagen actúa estática en el fondo, creando parallax 100% nativo y perfecto */
    }
    <div class="fixed top-0 left-0 w-full h-screen -z-10 bg-theme-dark">
      {
        optimizedImage ? (
          <Image
            src={optimizedImage}
            alt={`Portada de ${data.title}`}
            class="w-full h-full object-cover opacity-40"
          />
        ) : (
          <div class="w-full h-full bg-white/5 opacity-40" />
        )
      }
    </div>

    {/* Filtro volumétrico de la zona inferior del hero hacia el negro puro */}
    <div
      class="absolute inset-0 bg-linear-to-t from-theme-dark via-theme-dark/30 to-transparent pointer-events-none z-0"
    >
    </div>

    {/* 3. Tipografía Monumental "Pegada y Viva" */}
    <div class="relative z-10 max-w-6xl mt-auto">
      <h1
        class="text-6xl md:text-8xl lg:text-9xl font-serif tracking-tighter antialiased leading-[1.05] flex flex-wrap gap-x-2 md:gap-x-4 lg:gap-x-6 gap-y-2 pt-4 pb-2"
      >
        {
          (data.title || "")
            .split(" ")
            .map((word: string) => (
              <span class="hero-word inline-block translate-y-6 opacity-0 blur-md transition-all duration-3000 ease-cinematic pb-2 bg-linear-to-b from-[#e0e0e0] to-[#e0e0e0]/20 bg-clip-text text-transparent drop-shadow-2xl">
                {word}
              </span>
            ))
        }
      </h1>

      <div
        class="hero-meta mt-10 font-mono text-xs opacity-0 translate-y-4 blur-sm flex items-center uppercase tracking-widest text-[#C8A98B] transition-all duration-1000 ease-cinematic border-l border-[#C8A98B]/30 pl-4"
      >
        <span>[ {data.category || "ARCHIVO CLASIFICADO"} ]</span>
        <span class="mx-4 opacity-50">—</span>
        <span>{data.date ? new Date(data.date).getFullYear() : "S/F"}</span>
      </div>
    </div>
  </section>

  {/* 5. Transición Fluida al Contenido */}
  <article
    class="w-full bg-theme-dark relative overflow-hidden z-20 pt-24 pb-32 px-6 md:px-8 shadow-[0_-20px_50px_rgba(18,20,19,1)]"
    style={`--theme-accent: ${activeAccent};`}
  >
    {/* Capas FX: Aura Atmosférica sutil */}
    <div
      class="pointer-events-none absolute inset-0 opacity-20"
      style="background: radial-gradient(circle at 50% 20%, var(--theme-accent) 0%, transparent 70%); mix-blend-screen;"
    >
    </div>

    <div class="max-w-3xl mx-auto relative z-10 px-6 md:px-0">
      {
        data.excerpt && (
          <div class="border-l border-[#C8A98B]/30 pl-8 mb-24 max-w-2xl">
            <p class="text-2xl md:text-3xl font-serif opacity-90 italic text-[#C8A98B] leading-relaxed tracking-wide">
              "{data.excerpt}"
            </p>
          </div>
        )
      }

      {/* Redacción Editorial */}
      <div
        class="prose prose-invert prose-lg max-w-none
        prose-p:font-serif prose-p:font-normal prose-p:not-italic prose-p:text-[1.25rem] prose-p:leading-[1.85] prose-p:tracking-[0.015em] prose-p:text-white/85 prose-p:mb-10 prose-p:text-left
        prose-headings:font-serif prose-headings:font-normal prose-headings:tracking-[-0.02em] prose-headings:text-white/95 prose-headings:mt-16 prose-headings:mb-8
        prose-strong:font-bold prose-strong:text-white/90
        prose-blockquote:border-none prose-blockquote:bg-white/5 prose-blockquote:text-white/90 prose-blockquote:p-12 prose-blockquote:md:-mx-20 prose-blockquote:rounded-2xl prose-blockquote:shadow-2xl prose-blockquote:text-2xl prose-blockquote:leading-snug prose-blockquote:font-serif prose-blockquote:italic
        prose-a:border-b prose-a:border-[#C8A98B]/40 prose-a:text-[#C8A98B] hover:prose-a:text-white transition-colors
        prose-p:first-of-type:first-letter:text-8xl prose-p:first-of-type:first-letter:font-serif prose-p:first-of-type:first-letter:text-[#C8A98B] prose-p:first-of-type:first-letter:mr-4 prose-p:first-of-type:first-letter:float-left prose-p:first-of-type:first-letter:leading-[0.7] prose-p:first-of-type:first-letter:mt-3
        prose-hr:border-t prose-hr:border-white/10 prose-hr:my-20"
      >
        {(() => {
          if (data.generador) {
            const html = marked.parse(data.generador) as string;
            const paragraphs = html.split('</p>');
            if (paragraphs.length > 4) {
              const middle = Math.floor(paragraphs.length / 2);
              const part1 = paragraphs.slice(0, middle).join('</p>') + '</p>';
              const part2 = paragraphs.slice(middle).join('</p>');
              return (
                <>
                  <div set:html={part1} />
                  <RelatedReading currentSlug={slug!} category={data.category ?? undefined} />
                  <div set:html={part2} />
                </>
              );
            }
            return <div set:html={html} />;
          }
          return (
            <>
              <Content />
              <RelatedReading currentSlug={slug!} category={data.category ?? undefined} />
            </>
          );
        })()}
      </div>
    </div>
    
    <ExploreMore currentSlug={slug!} category={data.category ?? undefined} />

    <SubstackPrefooter />

    <div
      class="max-w-2xl mx-auto relative z-10 pt-24 pb-32 text-center"
    >
      <a
        href="/archivo"
        class="inline-block font-mono text-[10px] border border-white/10 px-10 py-5 uppercase tracking-[0.3em] text-white/40 hover:bg-white/5 hover:border-[#C8A98B]/50 hover:text-[#C8A98B] transition-all duration-700 rounded-full"
      >
        Cerrar Archivo
      </a>
    </div>
  </article>

  {/* 4. Animación de Entrada "Aparición Volumétrica" */}
  <script>
    const setupHeroAnimation = () => {
      const heroSection = document.querySelector(".hero-section");
      if (!heroSection) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Revelar el H1 globalmente
              const h1 = entry.target.querySelector("h1");
              if (h1) h1.classList.add("revealed");

              // Animar palabras del H1 de manera secuencial (Stagger)
              const words = entry.target.querySelectorAll(".hero-word");
              words.forEach((word, index) => {
                setTimeout(
                  () => {
                    word.classList.remove(
                      "opacity-0",
                      "translate-y-6",
                      "blur-md",
                    );
                    word.classList.add(
                      "opacity-100",
                      "translate-y-0",
                      "blur-0",
                    );
                  },
                  index * 300 + 100,
                ); // 300ms delay entre cada palabra
              });

              // Animar meta al finalizar las palabras
              const meta = entry.target.querySelector(".hero-meta");
              if (meta) {
                setTimeout(
                  () => {
                    meta.classList.remove(
                      "opacity-0",
                      "translate-y-4",
                      "blur-sm",
                    );
                    meta.classList.add(
                      "opacity-100",
                      "translate-y-0",
                      "blur-0",
                    );
                  },
                  words.length * 150 + 400,
                ); // 400ms buffer after last word
              }

              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 },
      );

      observer.observe(heroSection);
    };

    // Ejecutar en render normal y tolerar view transitions
    document.addEventListener("DOMContentLoaded", setupHeroAnimation);
    document.addEventListener("astro:page-load", setupHeroAnimation);
  </script>

  <style>
    /* Soporte de la curva Bézier cinemática */
    .ease-cinematic {
      transition-timing-function: cubic-bezier(0.25, 1, 0.5, 1);
    }
  </style>
</Layout>
