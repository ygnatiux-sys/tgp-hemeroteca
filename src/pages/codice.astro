---
import Layout from '../layouts/Layout.astro';
import KitLeadMagnet from '../components/KitLeadMagnet.astro';

/**
 * Codice.astro
 * Landing page para el Lead Magnet "El Códice Fundacional".
 */
---

<Layout title="El Códice Fundacional | The Great Puzzle Project">
  <main class="min-h-screen flex flex-col items-center justify-center pt-24 pb-12 overflow-hidden">
    
    <!-- Fondo Radial Decorativo -->
    <div class="fixed inset-0 pointer-events-none -z-10 bg-[#050505]">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120vw] h-screen bg-sky-950/20 rounded-full blur-[180px] opacity-30"></div>
    </div>

    <!-- Componente Principal -->
    <div class="w-full flex items-center justify-center px-4 animate-fade-in-slow">
      <KitLeadMagnet />
    </div>

    <!-- Texto de Apoyo Inferior -->
    <div class="mt-12 text-center max-w-lg px-6">
      <p class="font-serif italic text-white/20 text-sm leading-relaxed">
        "La verdad no es algo que se encuentra, es algo que se recuerda."
      </p>
    </div>

  </main>
</Layout>

<style>
  .animate-fade-in-slow {
    animation: fadeIn 3s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
