        <div class="flex flex-col gap-1">
          <span class="text-[9px] font-mono text-[#2483EB] uppercase tracking-widest">NEWSLETTER SECRETA</span>
          <h5 class="text-sm font-serif text-white/80 group-hover:text-[#2483EB] transition-colors leading-snug line-clamp-2">
            Suscríbete en Kit
