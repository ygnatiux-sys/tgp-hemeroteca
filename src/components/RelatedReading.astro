---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

interface Props {
  currentSlug: string;
  category?: string;
  limit?: number;
}

const { currentSlug, category, limit = 2 } = Astro.props;

const allEssays = await getCollection("ensayos");
const relatedEssays = allEssays
  .filter(essay => essay.id.replace(/\/index$/, "") !== currentSlug && (category ? essay.data.category === category : true))
  .sort(() => Math.random() - 0.5)
  .slice(0, limit);

// Importar imágenes
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/ensayos/**/*.{jpeg,jpg,png,gif,webp,avif}",
);
---

<div class="not-prose my-16 py-12 border-y border-white/5 bg-white/2 -mx-6 md:-mx-12 lg:-mx-24 px-6 md:px-24">
  <div class="flex flex-col md:flex-row items-center gap-12 max-w-4xl mx-auto">
    <div class="flex-1 space-y-4">
      <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#C8A98B] block mb-2">Lectura Relacionada</span>
      <h4 class="text-3xl font-serif text-white/90 leading-tight">Únete a la investigación</h4>
      <p class="text-sm text-white/40 leading-relaxed max-w-sm">
        Accede a nuestros documentos exclusivos y mantente al tanto de los nuevos descubrimientos de la colección.
      </p>
    </div>
    
    <div class="flex-1 w-full grid grid-cols-1 gap-6">
      <!-- Enlace a El Códice Fundacional -->
      <a href="/codice" class="group flex items-center gap-4 bg-white/5 p-3 rounded-xl hover:bg-white/10 transition-all border border-white/5 hover:border-[#C8A98B]/30">
        <div class="w-20 h-20 rounded-lg overflow-hidden shrink-0 bg-theme-dark relative">
          <img src="/images/lead-magnet/book-cover.jpg" alt="El Códice Fundacional" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" />
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[9px] font-mono text-[#C8A98B] uppercase tracking-widest">DOCUMENTO EXCLUSIVO</span>
