---
---
<section class="max-w-2xl mx-auto px-6 mt-40 mb-20 relative group">
  {/* Contenedor Compacto Estilo Atlantic */}
  <div class="relative overflow-hidden bg-white/3 backdrop-blur-xl border border-white/5 rounded-3xl p-8 md:p-12 flex flex-col items-center text-center gap-8 transition-all duration-700 hover:border-[#FF6719]/20">
    
    <div class="flex flex-col items-center gap-4">
      {/* Icono Reducido */}
      <div class="w-12 h-12 bg-[#FF6719]/10 border border-[#FF6719]/20 flex items-center justify-center rounded-2xl shadow-xl transition-transform duration-500 group-hover:scale-110">
        <svg viewBox="0 0 24 24" class="w-6 h-6 fill-[#FF6719]" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.539 8.242H1.46V5.406h21.078v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.078V0z"/>
        </svg>
      </div>
      
      <div>
        <h3 class="font-serif text-2xl text-white/90 leading-tight tracking-tight">
          La Bitácora de <span class="text-[#FF6719] font-medium">Substack</span>
        </h3>
        <p class="font-mono text-[10px] uppercase tracking-[0.3em] mt-3 text-white/30 leading-relaxed">
          Pensamiento crítico en tu buzón.
        </p>
      </div>
    </div>

    {/* Formulario Compacto */}
    <form class="flex flex-col sm:flex-row items-stretch gap-2 w-full max-w-sm relative z-10">
      <input 
        type="email" 
        placeholder="Tu correo..." 
        required
        class="bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white font-mono text-xs focus:border-[#FF6719]/40 focus:bg-white/8 outline-none w-full transition-all placeholder:text-white/10"
      />
      <button 
        type="submit" 
        class="bg-white/8 border border-white/10 text-white/80 hover:text-white hover:bg-[#FF6719] hover:border-[#FF6719] px-6 py-4 rounded-xl font-mono text-[10px] font-bold uppercase tracking-[0.2em] transition-all active:scale-[0.98]"
      >
        Unirse
      </button>
    </form>

    {/* Glow Minimalista */}
    <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-[#FF6719]/5 rounded-full blur-[100px] pointer-events-none group-hover:bg-[#FF6719]/10 transition-all duration-1000"></div>
  </div>
</section>
