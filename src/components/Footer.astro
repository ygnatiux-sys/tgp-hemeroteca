      </div>

      {/* Columna 4: Contacto */}
      <div class="flex flex-col items-start md:items-end">
        <button id="open-dossier" class="font-mono text-xs tracking-widest uppercase border border-white/20 px-6 py-3 hover:bg-[#C8A98B] hover:border-[#C8A98B] hover:text-theme-dark transition-colors duration-500 cursor-pointer">
          [ Contactar a Xavier ]
        </button>
      </div>

    </div>

    {/* Fila Inferior: Créditos y Ubicación */}
    <div class="flex flex-col md:flex-row gap-8 justify-between items-start md:items-end w-full mt-16 pt-8 border-t border-white/10">
      <div class="font-mono text-[10px] tracking-[0.2em] uppercase opacity-40 max-w-sm">
        © 2026 THE GREAT PUZZLE PROJECT. INVESTIGACIÓN Y CARTOGRAFÍA POR XAVIER BENÍTEZ.
      </div>
      <a href="https://share.google/2jdBPO5AZhrjplGgj" target="_blank" rel="noopener noreferrer" class="font-mono text-[10px] tracking-[0.2em] uppercase text-white/40 hover:text-[#C8A98B] hover:opacity-100 transition-all duration-700 ease-in-out cursor-pointer text-left md:text-right">
        BURZACO, BUENOS AIRES — 34°49'28"S 58°22'46"W
      </a>
    </div>
