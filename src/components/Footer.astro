</footer>

{/* Dossier de Contacto (Modal) */}
<dialog id="contact-dossier" class="fixed inset-0 m-auto bg-[#161617] text-white/90 p-0 max-w-4xl w-full border border-white/10 backdrop:bg-black/80 backdrop:backdrop-blur-sm shadow-2xl">
  <div class="grid grid-cols-1 md:grid-cols-2 h-full min-h-[500px]">
    
    {/* Lado Izquierdo: Imagen */}
    <div class="w-full h-48 md:h-full bg-black/50 border-r border-white/5 relative overflow-hidden">
      <img 
        src="/perfil.webp" 
        alt="Xavier Benítez" 
        class="object-cover w-full h-full opacity-70 grayscale mix-blend-luminosity hover:grayscale-0 hover:mix-blend-normal transition-all duration-1000"
      >
      <div class="absolute inset-0 bg-linear-to-b from-transparent to-[#161617]/50 pointer-events-none md:hidden"></div>
    </div>

    {/* Lado Derecho: Contenido */}
    <div class="p-12 relative flex flex-col justify-center h-full overflow-y-auto">
      <button id="close-dossier" class="absolute top-6 right-8 font-mono text-[10px] tracking-widest uppercase opacity-50 hover:text-[#C8A98B] hover:opacity-100 transition-all cursor-pointer">
        [ CERRAR DOSSIER ]
      </button>

      <div class="mt-8 md:mt-0">
        <h2 class="font-serif text-5xl md:text-6xl text-[#F5F5F7] tracking-tight">Xavier Benítez</h2>
        <p class="font-mono text-xs uppercase opacity-50 my-6 tracking-widest border-b border-white/10 pb-6">
          Investigador & Cartógrafo Epistémico
        </p>

        <div class="flex flex-col gap-6 mt-8 relative z-10">
          <div>
            <span class="block font-mono text-[10px] opacity-40 uppercase tracking-widest mb-2">Canal Primario</span>
            <a href="https://mail.google.com/mail/?view=cm&fs=1&to=thegreatpuzzleproject@gmail.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 font-mono text-sm opacity-80 hover:text-[#C8A98B] hover:opacity-100 transition-all">
              <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              thegreatpuzzleproject@gmail.com
            </a>
          </div>

          <div>
            <span class="block font-mono text-[10px] opacity-40 uppercase tracking-widest mb-2">Canal Cifrado</span>
            <a href="https://wa.me/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 font-mono text-sm opacity-80 hover:text-[#C8A98B] hover:opacity-100 transition-all">
              <svg class="w-4 h-4 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              Iniciar Transmisión Cifrada
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</dialog>

<style>
  /* Animación nativa de entrada para el dialog y backdrop */
  dialog[open] {
    animation: fadeIn 0.4s ease-out normal;
  }
  
  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
    animation: fadeIn 0.4s ease-out normal;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Escondemos la barra de scroll en el contenido derecho para mantener la estética pulcra */
  .overflow-y-auto::-webkit-scrollbar {
    width: 4px;
  }
  .overflow-y-auto::-webkit-scrollbar-track {
    background: transparent;
  }
  .overflow-y-auto::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
  }
</style>

<script>
  // Lógica nativa para instanciar el Modal HTML5
  document.addEventListener('DOMContentLoaded', () => {
    // Al usar Astro view transitions, necesitamos delegación de eventos o volver a setear los listeners
    // Para simplificar, buscamos los IDs directamente.
    const setupModal = () => {
      const dialog = document.getElementById('contact-dossier') as HTMLDialogElement;
      const openBtn = document.getElementById('open-dossier');
      const closeBtn = document.getElementById('close-dossier');

      if (dialog && openBtn && closeBtn) {
        // Remover listeners anteriores (si hay re-render) clonando el botón es una técnica rápida, pero aquí usaremos onclick
        openBtn.onclick = () => {
          dialog.showModal();
          document.body.style.overflow = 'hidden'; // Bloquear scroll de fondo
        };

        closeBtn.onclick = () => {
          dialog.close();
          document.body.style.overflow = 'auto'; // Restaurar scroll
        };

        // Cerrar al clickear el backdrop (espacio fuera del modal)
        dialog.onclick = (e) => {
          const dialogDimensions = dialog.getBoundingClientRect();
          if (
            e.clientX < dialogDimensions.left ||
            e.clientX > dialogDimensions.right ||
            e.clientY < dialogDimensions.top ||
            e.clientY > dialogDimensions.bottom
          ) {
            dialog.close();
            document.body.style.overflow = 'auto';
          }
        };
      }
    };

    setupModal();
    // Soporte para Astro View Transitions si las usas en el layout
    document.addEventListener('astro:page-load', setupModal);
  });
</script>
