---
// Header Component Institucional (Dark Academia Premium)
---

<header class="fixed top-0 w-full z-100 bg-black/60 backdrop-blur-xl border-b border-white/5 transition-all duration-700">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-5 flex justify-between items-center">
    <div class="flex items-center gap-6">
      <a href="/" class="group flex flex-row items-center gap-3">
        <div class="brand-element w-8 h-8 rounded-full border border-white/20 flex items-center justify-center overflow-hidden group-hover:border-[#C8A98B]/50 transition-all duration-700 opacity-0 blur-md translate-y-2">
          <img src="/favicon.png" alt="TGP Logo" class="w-5 h-5 object-contain brightness-150 grayscale" />
        </div>
        <div class="brand-element flex flex-col opacity-0 blur-md translate-y-2">
          <span class="font-serif tracking-[0.2em] text-[10px] uppercase text-transparent bg-clip-text bg-linear-to-b from-[#e0e0e0] to-[#e0e0e0]/20 drop-shadow-2xl group-hover:text-[#C8A98B] transition-all duration-700">
            The Great Puzzle Project
          </span>
        </div>
      </a>
      
      {/* Tagline de la Franja */}
      <div class="hidden lg:block brand-element border-l border-white/10 pl-6 opacity-0 blur-md translate-y-2">
        <span class="font-mono text-[8px] uppercase tracking-[0.4em] text-white/30 italic">
          Investigación & Cartografía Epistémica
        </span>
      </div>
    </div>
    
    <nav class="flex items-center gap-8">
      <a href="/" class="font-mono text-[9px] uppercase tracking-[0.3em] text-white/40 hover:text-white transition-all duration-500">Inicio</a>
      <a href="/manifiesto" class="font-mono text-[9px] uppercase tracking-[0.3em] text-white/40 hover:text-white transition-all duration-500">Manifiesto</a>
      <a href="/archivo" class="font-mono text-[9px] uppercase tracking-[0.3em] text-white/40 hover:text-white transition-all duration-500">Archivo</a>
      <a href="/codice" class="px-4 py-2 border border-white/10 rounded-full font-mono text-[9px] uppercase tracking-[0.3em] text-white/80 hover:text-white hover:border-white/30 transition-all duration-500 bg-white/5">El Códice</a>
    </nav>
  </div>
</header>

<script>
  const setupHeaderReveal = () => {
    const elements = document.querySelectorAll('.brand-element');
    elements.forEach((el, index) => {
      setTimeout(() => {
        el.classList.remove('opacity-0', 'blur-md', 'translate-y-2');
        el.classList.add('opacity-100', 'blur-0', 'translate-y-0');
      }, index * 500 + 500);
    });
  };

  document.addEventListener('DOMContentLoaded', setupHeaderReveal);
  document.addEventListener('astro:page-load', setupHeaderReveal);
</script>

<style>
  .brand-element {
    transition: all 3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
</style>
